<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Simple Budget Tracker</title>
</head>
<body>
  <h2>Budget Tracker</h2>

  <!-- Income -->
  <div>
    <label>Income: </label>
    <input type="number" id="incomeInput" placeholder="Enter income">
    <button onclick="addIncome()">Add Income</button>
  </div>

  <!-- Expense -->
  <div>
    <label>Expense: </label>
    <input type="text" id="expenseDesc" placeholder="Description">
    <input type="number" id="expenseAmount" placeholder="Amount">
    <button onclick="addExpense()">Add Expense</button>
  </div>

  <!-- Summary -->
  <h3>Summary</h3>
  <p id="incomeDisplay">Total Income: 0</p>
  <p id="expenseDisplay">Total Expenses: 0</p>
  <p id="balanceDisplay">Remaining Balance: 0</p>

  <script>
    let income = 0;
    let expenses = 0;

    function addIncome() {
      const amount = parseFloat(document.getElementById("incomeInput").value);
      if (!isNaN(amount) && amount > 0) {
        income += amount;
        updateSummary();
        document.getElementById("incomeInput").value = "";
      }
    }

    function addExpense() {
      const amount = parseFloat(document.getElementById("expenseAmount").value);
      if (!isNaN(amount) && amount > 0) {
        expenses += amount;
        updateSummary();
        document.getElementById("expenseDesc").value = "";
        document.getElementById("expenseAmount").value = "";
      }
    }

    function updateSummary() {
      document.getElementById("incomeDisplay").textContent = "Total Income: " + income;
      document.getElementById("expenseDisplay").textContent = "Total Expenses: " + expenses;
      document.getElementById("balanceDisplay").textContent = "Remaining Balance: " + (income - expenses);
    }
  </script>
</body>
</html>